# ==============================================================================
# LiteResearcher Configuration
# Copy this file to .env and modify as needed: cp .env.example .env
# ==============================================================================

# ==============================================================================
# LLM / Model Configuration
# ==============================================================================
MODEL=/path/to/your/model

# SGLang server endpoint
SGLANG_API_BASE=http://127.0.0.1:6001/v1
SGLANG_API_KEY=EMPTY
PLANNING_PORTS=6001
MAIN_MAX_MODEL_LEN=90000

# Tokenizer path for accurate token counting
# TOKEN_COUNT_MODEL_PATH=/path/to/tokenizer

# ==============================================================================
# Search Service (Google Serper)
# ==============================================================================
SERPER_KEY_ID=your_serper_api_key_here
SEARCH_SERVER_PORT=8001

# ==============================================================================
# Browser Service (Jina Reader by default; ScrapeDo optional + LLM Summary)
# ==============================================================================
# BROWSER_PROVIDER selects the page-fetch backend: 'jina' (default) or 'scrapedo'.
# JINA_API_KEY is optional; setting it raises Jina Reader rate limits.
# SCRAPEDO_API_KEY is required only if BROWSER_PROVIDER=scrapedo (or used as fallback).
BROWSER_PROVIDER=jina
JINA_API_KEY=
SCRAPEDO_API_KEY=
BROWSER_SERVER_PORT=8002

# Summary model for webpage content extraction
SUMMARY_PORTS=7001
SUMMARY_MODEL_NAME=your_summary_model_name
# VISIT_API_BASE=http://127.0.0.1:7001/v1

# ==============================================================================
# Inference Settings
# ==============================================================================
TEMPERATURE=0.6
TOP_P=0.95
PRESENCE_PENALTY=1.1
MAX_WORKERS=20
ROLL_OUT_COUNT=1
MAX_LLM_CALL_PER_RUN=100
MAX_TIMEOUT_SECONDS=9000

# ==============================================================================
# Proxy (optional)
# ==============================================================================
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
