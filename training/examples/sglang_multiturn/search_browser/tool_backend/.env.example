# =======================================================================
#  LiteResearcher  Browse / Search / LLM-Judge service config
#  Copy to .env and fill in your own endpoints / keys.
#  All entries use plain key=value (python-dotenv format, NOT shell export).
# =======================================================================

# ---- Browse service backend (Scrape.do or similar) ----
SCRAPEDO_API_KEY=your-scrape-api-key-here

# ---- PostgreSQL cache for the Browse service ----
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-pg-password
PG_DATABASE=postgres

# ---- Summary LLM (used by Browse to summarize pages) ----
# Any OpenAI-compatible chat-completions endpoint.
SUMMARY_API_BASE=http://127.0.0.1:7000/v1
SUMMARY_MODEL_NAME=Qwen3-4B-Instruct-2507-FP8
SUMMARY_API_KEY=EMPTY

# ---- LLM Judge (reward scoring during RL training) ----
# Defaults to SUMMARY_API_BASE if left empty.
LLM_JUDGE_API_BASE=http://127.0.0.1:7000/v1
LLM_JUDGE_MODEL=Qwen3-4B-Instruct-2507-FP8
LLM_JUDGE_MAX_RETRIES=3
LLM_JUDGE_TIMEOUT=360
